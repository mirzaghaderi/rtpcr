set.seed(1)
Genotype  <- rep(c("WT", "Mutant"), each = 12)
Treatment <- rep(rep(c("Control", "Salt"), each = 3), times = 2)
Rep       <- rep(1:3, times = 4)
data_2factor_3ref <- data.frame(
Genotype  = Genotype,
Treatment = Treatment,
Rep       = Rep,
TargetGene1 = 2, Ct_TargetGene1 = round(rnorm(24, 24, 0.4), 2),
TargetGene2 = 2, Ct_TargetGene2 = round(rnorm(24, 27, 0.5), 2),
TargetGene3 = 2, Ct_TargetGene3 = round(rnorm(24, 22, 0.3), 2),
RefGene1 = 2, Ct_RefGene1 = round(rnorm(24, 19, 0.2), 2),
RefGene2 = 2, Ct_RefGene2 = round(rnorm(24, 20, 0.2), 2),
RefGene3 = 2, Ct_RefGene3 = round(rnorm(24, 18.5, 0.2), 2)
)
head(data_2factor_3ref)
library(rtpcr)
res <- ANOVA_DDCt(
x = data_2factor_3ref,
specs = "Treatment | Genotype",   # comparing Treatment in each level of Genotype
numOfFactors = 2,
numberOfrefGenes = 3,
block = NULL
)
df <- res$relativeExpression
plotFactor(
df,
x_col = "contrast",
y_col = "RE",
group_col = "Genotype",
facet_col = "gene",
Lower.se_col = "Lower.se.RE",
Upper.se_col = "Upper.se.RE",
color = "black",
fill_colors = c("red", "green"),
letters_col = "sig",
removeCalibratorCols = F,
legend_position = c(0.1,0.85)
)
plotFactor(
df,
x_col = "contrast",
y_col = "RE",
group_col = "Genotype",
facet_col = "gene",
Lower.se_col = "Lower.se.RE",
Upper.se_col = "Upper.se.RE",
color = "black",
letters_col = "sig",
removeCalibratorCols = T,
legend_position = c(0.1,0.85)
)
